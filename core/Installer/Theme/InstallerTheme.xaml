    <SolidColorBrush x:Key="FooterTextBrush" Color="#80AEB6BE"/>
    <SolidColorBrush x:Key="CaptionGlyphBrush" Color="#FFC4CBD2"/>

    <SolidColorBrush x:Key="WindowGlassBrush" Color="#C4050608"/>
