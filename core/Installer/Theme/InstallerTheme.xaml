<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- THEME: Minimalism Dark — brush values kept byte-for-byte in sync with
         core\Settings\Theme\Themes\MinimalDark.xaml so the installer looks
         like a native part of the Settings app. True black, flat surfaces,
         glass effects muted; the DWM acrylic backdrop does the work. -->

    <Color x:Key="AccentColor">#FF4CA3E8</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF4CA3E8"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#FF7FBFF2"/>
