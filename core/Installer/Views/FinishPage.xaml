<UserControl x:Class="CKFlip3D.Installer.Views.FinishPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="36,24,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="GlyphBlock" Text="&#xE930;" FontFamily="Segoe MDL2 Assets"
                       FontSize="52" HorizontalAlignment="Center"
                       Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock x:Name="TitleBlock" FontSize="24" FontWeight="SemiBold" Margin="0,16,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="MessageBlock" FontSize="12.5" Margin="0,12,0,0" MaxWidth="460"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <StackPanel x:Name="LaunchPanel" Orientation="Horizontal" Margin="0,28,0,0"
                        HorizontalAlignment="Center">
                <Button Content="Launch CKFlip3D" Style="{StaticResource AccentButton}"
                        MinWidth="150" Click="BtnLaunchCore_Click"/>
                <Button Content="Open Settings" Style="{StaticResource AeroButton}"
                        MinWidth="130" Margin="12,0,0,0" Click="BtnLaunchSettings_Click"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <Button Content="Close" Style="{StaticResource AeroButton}" MinWidth="92"
                    HorizontalAlignment="Right" Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</UserControl>
