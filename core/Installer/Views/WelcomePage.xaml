<UserControl x:Class="CKFlip3D.Installer.Views.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="36,24,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image x:Name="Logo" Source="pack://application:,,,/Assets/CKFlip3D.png"
                   Width="84" Height="84" RenderOptions.BitmapScalingMode="HighQuality"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="CKFlip3D" FontSize="30" FontWeight="SemiBold" Margin="0,14,0,0"
                       HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="The 3D window switcher for Windows 11" FontSize="13.5"
                       Margin="0,6,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock Text="Version 1.0.0" FontSize="11.5" Margin="0,18,0,0"
                       HorizontalAlignment="Center" Foreground="{DynamicResource TextFaintBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource AeroButton}" MinWidth="92"
                        Click="BtnCancel_Click"/>
                <Button Content="Next" Style="{StaticResource AccentButton}" MinWidth="112"
                        Margin="10,0,0,0" Click="BtnNext_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
