<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ====================================================================
         Aero-styled control templates. All chrome is drawn procedurally.
         Glass recipe (see issueresources docs): matte dark base + top-half
         sheen + 1px bright rim; hover lights the same button up instead of
         recoloring it; pressed physically depresses with a short animation.
         ==================================================================== -->

    <Style x:Key="AeroFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="-2" RadiusX="4" RadiusY="4"
                               Stroke="#805A9FD4" StrokeThickness="1" StrokeDashArray="1 2"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================= Buttons ================= -->

    <Style x:Key="AeroButton" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="MinHeight" Value="29"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource AeroFocusVisual}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- soft outer bloom on hover -->
                        <Border x:Name="Glow" CornerRadius="4" Margin="-2" Opacity="0"
                                Background="#3863C6FF" BorderThickness="1" BorderBrush="#5063C6FF"/>
                        <Border x:Name="Face" CornerRadius="3"
                                Background="{DynamicResource ButtonFaceBrush}"
                                BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                            <Grid>
                                <!-- hover wash: same button, lights up -->
                                <Border x:Name="HoverFace" CornerRadius="2.5" Opacity="0"
                                        Background="{DynamicResource ButtonHoverBrush}"/>
                                <!-- pressed body -->
                                <Border x:Name="PressedFace" CornerRadius="2.5" Opacity="0"
                                        Background="{DynamicResource ButtonPressedBrush}"/>
                                <!-- top-half glass sheen -->
                                <Border x:Name="Sheen" VerticalAlignment="Top" Height="14"
                                        CornerRadius="2.5,2.5,0,0" Margin="1,1,1,0" Opacity="0.85"
                                        Background="{DynamicResource ControlSheenBrush}"/>
                                <!-- bright top rim (glass lip) -->
                                <Border CornerRadius="2.5" BorderThickness="1"
                                        BorderBrush="{DynamicResource ControlGlassLipBrush}"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True">
                                    <ContentPresenter.RenderTransform>
                                        <TranslateTransform x:Name="ContentShift" Y="0"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Face" Property="BorderBrush" Value="{DynamicResource ButtonHoverBorderBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverFace" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.24"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverFace" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.24"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.85" Duration="0:0:0.24"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedFace" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.25" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="ContentShift" Storyboard.TargetProperty="Y"
                                                         To="1" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedFace" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.85" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="ContentShift" Storyboard.TargetProperty="Y"
                                                         To="0" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Face" Property="Opacity" Value="0.45"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource AeroButton}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Glow" CornerRadius="4" Margin="-2" Opacity="0"
                                Background="#4063C6FF" BorderThickness="1" BorderBrush="#8063C6FF"/>
                        <Border x:Name="Face" CornerRadius="3"
                                Background="{DynamicResource AccentButtonBrush}"
                                BorderBrush="#FF1D5F99" BorderThickness="1">
                            <Grid>
                                <Border x:Name="HoverFace" CornerRadius="2.5" Opacity="0"
                                        Background="{DynamicResource AccentButtonHoverBrush}"/>
                                <Border x:Name="PressedFace" CornerRadius="2.5" Opacity="0"
                                        Background="{DynamicResource AccentBrush}"/>
                                <Border x:Name="Sheen" VerticalAlignment="Top" Height="14"
                                        CornerRadius="2.5,2.5,0,0" Margin="1,1,1,0" Opacity="0.9">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#80FFFFFF" Offset="0"/>
                                            <GradientStop Color="#30FFFFFF" Offset="0.78"/>
                                            <GradientStop Color="#14FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border CornerRadius="2.5" BorderThickness="1"
                                        BorderBrush="{DynamicResource ControlGlassLipBrush}"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True">
                                    <ContentPresenter.RenderTransform>
                                        <TranslateTransform x:Name="ContentShift" Y="0"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverFace" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.24"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverFace" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.24"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.9" Duration="0:0:0.24"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedFace" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.3" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="ContentShift" Storyboard.TargetProperty="Y"
                                                         To="1" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedFace" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.9" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="ContentShift" Storyboard.TargetProperty="Y"
                                                         To="0" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Face" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource AeroButton}">
        <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Glow" CornerRadius="4" Margin="-2" Opacity="0"
                                Background="#30E86F5E" BorderThickness="1" BorderBrush="#60E86F5E"/>
                        <Border x:Name="Face" CornerRadius="3"
                                Background="{DynamicResource DangerButtonBrush}"
                                BorderBrush="{DynamicResource DangerBorderBrush}" BorderThickness="1">
                            <Grid>
                                <Border x:Name="HoverFace" CornerRadius="2.5" Opacity="0"
                                        Background="{DynamicResource DangerButtonHoverBrush}"/>
                                <Border x:Name="PressedFace" CornerRadius="2.5" Opacity="0"
                                        Background="#FF2E1D1F"/>
                                <Border x:Name="Sheen" VerticalAlignment="Top" Height="14"
                                        CornerRadius="2.5,2.5,0,0" Margin="1,1,1,0" Opacity="0.7"
                                        Background="{DynamicResource ControlSheenBrush}"/>
                                <Border CornerRadius="2.5" BorderThickness="1"
                                        BorderBrush="{DynamicResource ControlGlassLipBrush}"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True">
                                    <ContentPresenter.RenderTransform>
                                        <TranslateTransform x:Name="ContentShift" Y="0"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Face" Property="BorderBrush" Value="#FFA86058"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverFace" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.95" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.24"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverFace" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.24"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.24"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedFace" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.2" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="ContentShift" Storyboard.TargetProperty="Y"
                                                         To="1" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedFace" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="ContentShift" Storyboard.TargetProperty="Y"
                                                         To="0" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Face" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================= Toggle switch (styled CheckBox) ================= -->

    <Style x:Key="AeroToggle" TargetType="CheckBox">
        <Setter Property="FocusVisualStyle" Value="{StaticResource AeroFocusVisual}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="44" Height="20">
                        <!-- accent bloom behind the switch when ON -->
                        <Border x:Name="OnGlow" CornerRadius="12" Margin="-3" Opacity="0"
                                Background="#3863C6FF"/>
                        <!-- track: off layer always there, on layer fades in -->
                        <Border CornerRadius="10" Background="{DynamicResource ToggleOffBrush}"
                                BorderBrush="{DynamicResource ToggleOffBorderBrush}" BorderThickness="1"/>
                        <Border x:Name="OnTrack" CornerRadius="10" Opacity="0"
                                Background="{DynamicResource ToggleOnBrush}"
                                BorderBrush="{DynamicResource ToggleOnBorderBrush}" BorderThickness="1"/>
                        <!-- glass sheen on the track -->
                        <Border CornerRadius="10,10,4,4" Height="9" VerticalAlignment="Top" Margin="2,1.5,2,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#48FFFFFF" Offset="0"/>
                                    <GradientStop Color="#0AFFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- knob -->
                        <Border x:Name="Knob" Width="16" Height="16" CornerRadius="8"
                                HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0"
                                Background="{DynamicResource ToggleKnobBrush}"
                                BorderBrush="{DynamicResource ToggleKnobBorderBrush}" BorderThickness="1"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="KnobShift" X="0"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="0.5" Opacity="0.35"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobShift" Storyboard.TargetProperty="X"
                                                         To="24" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="OnTrack" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="OnGlow" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobShift" Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="OnTrack" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="OnGlow" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Knob" Property="BorderBrush" Value="{DynamicResource ButtonHoverBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================= Slider ================= -->

    <Style x:Key="SliderThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <Border x:Name="Glow" Width="22" Height="22" CornerRadius="11" Opacity="0"
                                Background="#3063C6FF"/>
                        <Border x:Name="Knob" Width="14" Height="14" CornerRadius="7"
                                Background="{DynamicResource ToggleKnobBrush}"
                                BorderBrush="#FF7FA6C8" BorderThickness="1"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="KnobScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="0.5" Opacity="0.4"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobScale" Storyboard.TargetProperty="ScaleX"
                                                         To="0.9" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="KnobScale" Storyboard.TargetProperty="ScaleY"
                                                         To="0.9" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobScale" Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="KnobScale" Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SliderRepeatButton" TargetType="RepeatButton">
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AeroSlider" TargetType="Slider">
        <Setter Property="Height" Value="24"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource AeroFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <!-- groove: dark inset.  Inset 7px (half the thumb) on
                             both sides so its ends line up with the thumb-centre
                             extremes — no leftover gap at min/max. -->
                        <Border Height="5" CornerRadius="2.5" Margin="7,0"
                                Background="{DynamicResource SliderTrackBrush}"
                                BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"/>
                        <!-- filled part: rendered by the decrease button area -->
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Style="{StaticResource SliderRepeatButton}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Grid Background="Transparent">
                                                <!-- fill runs from the groove start to the thumb centre -->
                                                <Border Height="5" CornerRadius="2.5" Margin="7,0,-7,0"
                                                        Background="{DynamicResource SliderFillBrush}"
                                                        BorderBrush="#FF2A6CA4" BorderThickness="1">
                                                    <!-- thin top highlight on the fill -->
                                                    <Border Height="1.5" VerticalAlignment="Top" Margin="1,0.5,1,0"
                                                            CornerRadius="1" Background="#66FFFFFF"/>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Style="{StaticResource SliderRepeatButton}"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SliderThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================= ComboBox ================= -->

    <Style x:Key="AeroComboToggle" TargetType="ToggleButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Face" CornerRadius="3"
                            Background="{DynamicResource ButtonFaceBrush}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Border x:Name="HoverFace" CornerRadius="2.5" Opacity="0"
                                    Background="{DynamicResource ButtonHoverBrush}"/>
                            <Border x:Name="PressedFace" CornerRadius="2.5" Opacity="0"
                                    Background="{DynamicResource ButtonPressedBrush}"/>
                            <Border x:Name="Sheen" VerticalAlignment="Top" Height="13"
                                    CornerRadius="2.5,2.5,0,0" Margin="1,1,1,0" Opacity="0.85"
                                    Background="{DynamicResource ControlSheenBrush}"/>
                            <Border CornerRadius="2.5" BorderThickness="1"
                                    BorderBrush="{DynamicResource ControlGlassLipBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                </Grid.ColumnDefinitions>
                                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M0,0 L4,4.5 L8,0" Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Face" Property="BorderBrush" Value="{DynamicResource ButtonHoverBorderBrush}"/>
                            <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFace" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFace" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.24"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedFace" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.3" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedFace" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="Sheen" Storyboard.TargetProperty="Opacity"
                                                         To="0.85" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AeroComboBox" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="MinWidth" Value="150"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource AeroFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="Toggle" Style="{StaticResource AeroComboToggle}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False" ClickMode="Press"/>
                        <ContentPresenter Margin="10,0,26,0" VerticalAlignment="Center"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          IsHitTestVisible="False"/>
                        <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Slide"
                               StaysOpen="False">
                            <Border Margin="4,2,4,6" CornerRadius="4"
                                    Background="{DynamicResource ComboPopupBrush}"
                                    BorderBrush="{DynamicResource ComboPopupBorderBrush}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.55"/>
                                </Border.Effect>
                                <Grid>
                                    <!-- glass sheet: top sheen on the popup -->
                                    <Border Height="12" VerticalAlignment="Top" Margin="1,1,1,0"
                                            CornerRadius="3,3,0,0" Background="{DynamicResource CardHeaderBandBrush}"
                                            IsHitTestVisible="False"/>
                                    <ScrollViewer MaxHeight="240" Margin="2">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Padding" Value="9,5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bg" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{DynamicResource NavActiveBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================= ScrollBar (thin, glassy) ================= -->

    <Style x:Key="AeroScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bg" CornerRadius="4" Background="#5078A0C4" Margin="2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#A05A9FD4"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#C02D7DC1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar" x:Key="AeroScrollBar">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource SliderRepeatButton}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource SliderRepeatButton}"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource AeroScrollThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="10"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AeroScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}"/>
                        <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                   Style="{StaticResource AeroScrollBar}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================= Settings card (group panel) ================= -->
    <!-- Real glass card: raised gradient, 1px top glass lip, translucent
         header band with accent tick, darker bottom edge, soft shadow. -->

    <Style x:Key="SettingsCard" TargetType="HeaderedContentControl">
        <Setter Property="Margin" Value="0,0,0,14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="HeaderedContentControl">
                    <Border CornerRadius="6"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270"
                                              Color="#FF000000" Opacity="0.35"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- header band -->
                            <Border Grid.Row="0" Height="34" CornerRadius="5,5,0,0"
                                    Background="{DynamicResource CardHeaderBandBrush}">
                                <Grid>
                                    <Rectangle Width="3" Height="14" RadiusX="1.5" RadiusY="1.5"
                                               HorizontalAlignment="Left" VerticalAlignment="Center"
                                               Margin="14,0,0,0" Fill="{DynamicResource AccentBrush}"/>
                                    <TextBlock Style="{StaticResource CardHeaderText}"
                                               VerticalAlignment="Center" Margin="26,0,0,0"
                                               Text="{TemplateBinding Header}"/>
                                </Grid>
                            </Border>

                            <!-- glass seam under the header: dark line + faint light line -->
                            <Border Grid.Row="1" Height="2" VerticalAlignment="Top" IsHitTestVisible="False"
                                    Background="{DynamicResource CardSeamBrush}"/>

                            <!-- content -->
                            <ContentPresenter Grid.Row="1" Margin="18,14,18,16"/>

                            <!-- 1px top glass lip over everything -->
                            <Border Grid.Row="0" Grid.RowSpan="2" CornerRadius="5"
                                    BorderThickness="1" Margin="0"
                                    BorderBrush="{DynamicResource CardTopGlassBrush}"
                                    IsHitTestVisible="False"/>
                            <!-- darker bottom edge -->
                            <Border Grid.Row="1" Height="1" VerticalAlignment="Bottom"
                                    Margin="1,0,1,0" Background="#38000000"
                                    IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Thin separator between rows inside a card: glass seam (themed) -->
    <Style x:Key="RowSeparator" TargetType="Rectangle">
        <Setter Property="Height" Value="2"/>
        <Setter Property="Margin" Value="0,10,0,10"/>
        <Setter Property="Opacity" Value="0.75"/>
        <Setter Property="Fill" Value="{DynamicResource RowSeparatorBrush}"/>
    </Style>

</ResourceDictionary>
