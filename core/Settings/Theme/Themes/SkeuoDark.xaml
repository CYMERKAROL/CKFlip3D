<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ====================================================================
         THEME: Skeuomorphic Dark — the original CKFlip3D dark Aero glass.
         Every theme dictionary defines the exact same brush keys; consumers
         reference them via DynamicResource so a swap re-skins live UI.
         ==================================================================== -->

    <!-- Accent -->
    <Color x:Key="AccentColor">#FF3D90D8</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF3D90D8"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#FF7AB8EC"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#FF63C6FF"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFE6EFF7"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFA9BCCD"/>
    <SolidColorBrush x:Key="TextFaintBrush" Color="#FF7E92A5"/>
    <SolidColorBrush x:Key="TextOnGlassBrush" Color="#FFDCE8F4"/>
    <SolidColorBrush x:Key="TitleTextBrush" Color="#FFEAF3FB"/>
    <SolidColorBrush x:Key="FooterTextBrush" Color="#80C2D8EA"/>
    <SolidColorBrush x:Key="CaptionGlyphBrush" Color="#FFC9DBEA"/>
    <SolidColorBrush x:Key="NavIconBrush" Color="#FF9CC4E4"/>

    <!-- Window glass -->
    <LinearGradientBrush x:Key="WindowGlassBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#C8273140" Offset="0"/>
        <GradientStop Color="#B81D2632" Offset="0.10"/>
        <GradientStop Color="#AA161E28" Offset="0.45"/>
        <GradientStop Color="#B818202B" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="WindowGlassFallbackBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF222B37" Offset="0"/>
        <GradientStop Color="#FF19212B" Offset="0.45"/>
        <GradientStop Color="#FF1A222D" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="TitleSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#34FFFFFF" Offset="0"/>
        <GradientStop Color="#14FFFFFF" Offset="0.55"/>
        <GradientStop Color="#04FFFFFF" Offset="0.56"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="WindowReflectionBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1EFFFFFF" Offset="0"/>
        <GradientStop Color="#10E8F4FF" Offset="0.45"/>
        <GradientStop Color="#04DCEBFF" Offset="0.8"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <RadialGradientBrush x:Key="BackgroundRadialGlowBrush"
                         Center="0.16,0.18" GradientOrigin="0.16,0.18"
                         RadiusX="0.65" RadiusY="0.75">
        <GradientStop Color="#1A4FA8E8" Offset="0"/>
        <GradientStop Color="#0A3F88C8" Offset="0.55"/>
        <GradientStop Color="#003F88C8" Offset="1"/>
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="BackgroundVignetteBrush"
                         Center="0.5,0.42" GradientOrigin="0.5,0.42"
                         RadiusX="0.85" RadiusY="0.95">
        <GradientStop Color="#00000000" Offset="0"/>
        <GradientStop Color="#00000000" Offset="0.72"/>
        <GradientStop Color="#2C04080D" Offset="1"/>
    </RadialGradientBrush>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="ContentSurfaceBrush" Color="#D8151C26"/>
    <SolidColorBrush x:Key="ContentBorderBrush" Color="#2AFFFFFF"/>
    <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F226303C" Offset="0"/>
        <GradientStop Color="#F21E2832" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#FF344354"/>
    <SolidColorBrush x:Key="CardHeaderBrush" Color="#FF7FC0F0"/>
    <LinearGradientBrush x:Key="CardTopGlassBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#46FFFFFF" Offset="0"/>
        <GradientStop Color="#10FFFFFF" Offset="0.5"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardHeaderBandBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#16FFFFFF" Offset="0"/>
        <GradientStop Color="#08FFFFFF" Offset="0.7"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ControlSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5CFFFFFF" Offset="0"/>
        <GradientStop Color="#2BFFFFFF" Offset="0.78"/>
        <GradientStop Color="#10FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ControlGlassLipBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#46FFFFFF" Offset="0"/>
        <GradientStop Color="#08FFFFFF" Offset="0.5"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="InsetFieldBrush" Color="#FF141C26"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#FF2C3947"/>
    <SolidColorBrush x:Key="GlassEdgeBrush" Color="#26FFFFFF"/>
    <SolidColorBrush x:Key="WindowOuterBorderBrush" Color="#E0070C12"/>
    <SolidColorBrush x:Key="ApplyBarBrush" Color="#F01D2835"/>
    <SolidColorBrush x:Key="ModalOverlayBrush" Color="#7A04090F"/>
    <SolidColorBrush x:Key="ModalBorderBrush" Color="#FF45586C"/>
    <SolidColorBrush x:Key="ComboPopupBrush" Color="#F0202A36"/>
    <SolidColorBrush x:Key="ComboPopupBorderBrush" Color="#FF4A5C6F"/>
    <LinearGradientBrush x:Key="RowSeparatorBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF202A35" Offset="0"/>
        <GradientStop Color="#FF202A35" Offset="0.5"/>
        <GradientStop Color="#12FFFFFF" Offset="0.51"/>
        <GradientStop Color="#12FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardSeamBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#50000000" Offset="0"/>
        <GradientStop Color="#50000000" Offset="0.5"/>
        <GradientStop Color="#16FFFFFF" Offset="0.51"/>
        <GradientStop Color="#16FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Buttons -->
    <LinearGradientBrush x:Key="ButtonFaceBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF3D4854" Offset="0"/>
        <GradientStop Color="#FF333E49" Offset="0.55"/>
        <GradientStop Color="#FF2A343F" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF48586A" Offset="0"/>
        <GradientStop Color="#FF3C4F62" Offset="0.55"/>
        <GradientStop Color="#FF324558" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF222D38" Offset="0"/>
        <GradientStop Color="#FF1C2731" Offset="0.5"/>
        <GradientStop Color="#FF19232D" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF55667A"/>
    <SolidColorBrush x:Key="ButtonHoverBorderBrush" Color="#FF5A9FD4"/>
    <LinearGradientBrush x:Key="AccentButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF63AEE3" Offset="0"/>
        <GradientStop Color="#FF3E8FD0" Offset="0.49"/>
        <GradientStop Color="#FF2578BC" Offset="0.51"/>
        <GradientStop Color="#FF3D8CC9" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
