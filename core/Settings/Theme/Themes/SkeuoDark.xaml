        <GradientStop Color="#FF53393C" Offset="0"/>
        <GradientStop Color="#FF472F32" Offset="0.49"/>
        <GradientStop Color="#FF3A2628" Offset="0.51"/>
        <GradientStop Color="#FF422B2E" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DangerButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF6E4347" Offset="0"/>
        <GradientStop Color="#FF5E3539" Offset="0.49"/>
        <GradientStop Color="#FF4D282C" Offset="0.51"/>
        <GradientStop Color="#FF583034" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DangerBorderBrush" Color="#FF7E4E4C"/>
    <SolidColorBrush x:Key="DangerTextBrush" Color="#FFF2B3AB"/>

    <!-- Navigation -->
    <LinearGradientBrush x:Key="NavHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#22FFFFFF" Offset="0"/>
        <GradientStop Color="#0CFFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NavActiveBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#7058A0DC" Offset="0"/>
        <GradientStop Color="#503F7CB8" Offset="0.5"/>
        <GradientStop Color="#48336698" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="NavActiveBorderBrush" Color="#9070AEDE"/>

    <!-- Slider / toggle -->
    <LinearGradientBrush x:Key="SliderTrackBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF111A24" Offset="0"/>
        <GradientStop Color="#FF243140" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SliderFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF8CC6F0" Offset="0"/>
        <GradientStop Color="#FF3589CC" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ToggleOnBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF6FB4E8" Offset="0"/>
        <GradientStop Color="#FF2E7FC2" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ToggleOffBrush" StartPoint="0,0" EndPoint="0,1">
