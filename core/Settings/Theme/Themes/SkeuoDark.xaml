    </LinearGradientBrush>
    <SolidColorBrush x:Key="ToggleOffBorderBrush" Color="#FF4A5969"/>
    <SolidColorBrush x:Key="ToggleOnBorderBrush" Color="#FF20639B"/>
    <SolidColorBrush x:Key="ToggleKnobBorderBrush" Color="#FF8194A6"/>

</ResourceDictionary>
