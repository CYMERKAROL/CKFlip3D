<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- THEME: Glassmorphism — nearly everything translucent over the acrylic
         backdrop; frosted panels with bright white edges. -->

    <Color x:Key="AccentColor">#FF6FC3FF</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF6FC3FF"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#FFA4DAFF"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#FF8ED0FF"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#D8EAF2F8"/>
    <SolidColorBrush x:Key="TextFaintBrush" Color="#A0D6E4EE"/>
    <SolidColorBrush x:Key="TextOnGlassBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TitleTextBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="FooterTextBrush" Color="#90E6F1F8"/>
    <SolidColorBrush x:Key="CaptionGlyphBrush" Color="#FFEAF3FA"/>
    <SolidColorBrush x:Key="NavIconBrush" Color="#FFD6E9F8"/>

    <LinearGradientBrush x:Key="WindowGlassBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#42283442" Offset="0"/>
        <GradientStop Color="#36202B38" Offset="0.5"/>
        <GradientStop Color="#3E243040" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="WindowGlassFallbackBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF2A3644" Offset="0"/>
        <GradientStop Color="#FF202B38" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="TitleSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#48FFFFFF" Offset="0"/>
        <GradientStop Color="#1CFFFFFF" Offset="0.55"/>
        <GradientStop Color="#08FFFFFF" Offset="0.56"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="WindowReflectionBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#30FFFFFF" Offset="0"/>
        <GradientStop Color="#18F0F8FF" Offset="0.45"/>
        <GradientStop Color="#06E8F4FF" Offset="0.8"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <RadialGradientBrush x:Key="BackgroundRadialGlowBrush"
                         Center="0.16,0.18" GradientOrigin="0.16,0.18"
                         RadiusX="0.65" RadiusY="0.75">
        <GradientStop Color="#2462B8F0" Offset="0"/>
        <GradientStop Color="#0E4A98D0" Offset="0.55"/>
        <GradientStop Color="#004A98D0" Offset="1"/>
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="BackgroundVignetteBrush"
                         Center="0.5,0.42" GradientOrigin="0.5,0.42"
                         RadiusX="0.85" RadiusY="0.95">
        <GradientStop Color="#00000000" Offset="0"/>
        <GradientStop Color="#00000000" Offset="0.75"/>
        <GradientStop Color="#22000A14" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="ContentSurfaceBrush" Color="#2410161E"/>
    <SolidColorBrush x:Key="ContentBorderBrush" Color="#48FFFFFF"/>
    <SolidColorBrush x:Key="CardBrush" Color="#2CFFFFFF"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#52FFFFFF"/>
    <SolidColorBrush x:Key="CardHeaderBrush" Color="#FFBFE3FF"/>
    <LinearGradientBrush x:Key="CardTopGlassBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#70FFFFFF" Offset="0"/>
