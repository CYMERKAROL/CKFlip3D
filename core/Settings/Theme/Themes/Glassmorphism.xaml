        <GradientStop Color="#2CFFFFFF" Offset="0.51"/>
        <GradientStop Color="#2CFFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardSeamBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#30000000" Offset="0"/>
        <GradientStop Color="#30000000" Offset="0.5"/>
        <GradientStop Color="#30FFFFFF" Offset="0.51"/>
        <GradientStop Color="#30FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ButtonFaceBrush" Color="#30FFFFFF"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#4AFFFFFF"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#22000A14"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="ButtonHoverBorderBrush" Color="#FF8ED0FF"/>
