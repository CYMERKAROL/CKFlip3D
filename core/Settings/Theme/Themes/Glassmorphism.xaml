        <GradientStop Color="#C879C0F0" Offset="0"/>
        <GradientStop Color="#C84FA0DE" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AccentButtonBorderBrush" Color="#A0BFE3FF"/>
    <SolidColorBrush x:Key="DangerButtonBrush" Color="#46B0413C"/>
    <SolidColorBrush x:Key="DangerButtonHoverBrush" Color="#6EC44A42"/>
    <SolidColorBrush x:Key="DangerBorderBrush" Color="#8AF0A89E"/>
    <SolidColorBrush x:Key="DangerTextBrush" Color="#FFFFC9C0"/>

