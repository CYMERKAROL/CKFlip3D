<UserControl x:Class="CKFlip3D.Settings.Views.IgnoredAppsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Style="{StaticResource AeroScrollViewer}" VerticalScrollBarVisibility="Auto"
                  Padding="24,4,16,20">
        <StackPanel>

            <HeaderedContentControl Style="{StaticResource SettingsCard}" Header="Ignored applications">
                <StackPanel>
                    <TextBlock FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="While any of these executables is the foreground application, Win + Tab is passed straight through to Windows — CKFlip3D neither opens nor blocks anything. Entries match by full path or by file name. Remember to press Apply."/>

                    <Border CornerRadius="4" Background="{DynamicResource InsetFieldBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            MinHeight="180" MaxHeight="280">
                        <Grid>
                            <ListBox x:Name="AppList" Background="Transparent" BorderThickness="0"
                                     Margin="4" FontFamily="Consolas" FontSize="12"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bg" CornerRadius="3" Padding="{TemplateBinding Padding}"
                                                            Background="Transparent">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource NavHoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource NavActiveBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            <TextBlock x:Name="EmptyHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Segoe UI" FontSize="12" FontStyle="Italic"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       Text="No ignored applications yet — add an .exe below."/>
                        </Grid>
                    </Border>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ListStatus" VerticalAlignment="Center"
                                   FontFamily="Segoe UI" FontSize="12" FontStyle="Italic" Opacity="0"
                                   Foreground="{DynamicResource AccentBrush}"/>
                        <Button Grid.Column="1" Style="{StaticResource AeroButton}" Margin="0,0,8,0"
                                Content="Remove selected" Click="RemoveSelected_Click"/>
                        <Button Grid.Column="2" Style="{StaticResource AccentButton}"
                                Content="Add executable…" Click="AddExe_Click"/>
                    </Grid>
                </StackPanel>
            </HeaderedContentControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
