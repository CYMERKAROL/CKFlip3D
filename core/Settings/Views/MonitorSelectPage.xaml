<UserControl x:Class="CKFlip3D.Settings.Views.MonitorSelectPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Style="{StaticResource AeroScrollViewer}" VerticalScrollBarVisibility="Auto"
                  Padding="24,4,16,20">
        <StackPanel>

            <HeaderedContentControl Style="{StaticResource SettingsCard}" Header="Select where the cascade appears">
                <StackPanel>
                    <TextBlock FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Click a monitor below. The layout mirrors your physical arrangement; sizes, aspect ratios and orientation are to scale."/>

                    <!-- monitor map, built in code-behind -->
                    <Border Margin="0,14,0,0" CornerRadius="5" Background="#FF15222E"
                            BorderBrush="#FF44617C" BorderThickness="1"
                            HorizontalAlignment="Left">
                        <Canvas x:Name="MonitorCanvas" Width="560" Height="280" Margin="10"/>
                    </Border>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SelectionText" VerticalAlignment="Center"
                                   FontFamily="Segoe UI" FontSize="12.5"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="Cascade target: Primary monitor"/>
                        <Button Grid.Column="1" Style="{StaticResource AeroButton}"
                                Content="Use primary (default)" Click="UsePrimary_Click"/>
                    </Grid>
                </StackPanel>
            </HeaderedContentControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
